# ---- Frontend / API base ----
# Leave EMPTY on Vercel to use the built-in Next API routes (same origin).
# Set to http://localhost:4000 to use the legacy Express/Oracle backend locally.
NEXT_PUBLIC_API_URL=

# Log level for the browser logger: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info

# ---- Supabase (server-side, used by Next API routes) ----
# Transaction pooler connection string (Supabase → Project Settings → Database → Connection pooling, port 6543)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---- Auth ----
JWT_SECRET=troque-por-uma-string-longa-aleatoria
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha

# ---- Google Calendar OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# On Vercel: https://SEU-APP.vercel.app/api/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4173/api/google/callback
GOOGLE_CALENDAR_ID=primary

# Used to build redirect back to the app after OAuth (defaults to request origin)
APP_ORIGIN=
